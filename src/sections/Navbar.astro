---
import LanguageDropdown from "@/components/LanguageDropdown.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";

const navItems = [
    {
        title: "Sobre mí",
        url: "/#sobre-mi",
    },
    {
        title: "Experiencia",
        url: "/#experiencia",
    },
    {
        title: "Stack",
        url: "/#stack",
    },
    {
        title: "Contacto",
        url: "/#contacto",
    },
]
---

<header class="fixed top-4 left-0 right-0 z-50 px-4 md:px-8">
    <div class="max-w-7xl mx-auto flex items-center justify-between bg-slate-900/70 backdrop-blur-md border border-slate-700/50 rounded-full py-3 px-6 text-slate-200 shadow-lg">
        <a href="/" class="text-xl font-bold tracking-wider text-white hover:text-indigo-400 transition-colors">UCQ</a>
        <nav class="hidden md:flex items-center gap-6 lg:gap-8 text-sm font-medium">
            {
                navItems.map((link) => (
                    <a
                        class="hover:text-white transition-colors"
                        href={link.url}
                    >
                        {link.title}
                    </a>
                ))
            }
        </nav>
        <div class="flex items-center gap-4">
            <div class="hidden md:flex justify-center items-center">
                <LanguageDropdown />
                <ThemeToggle />
            </div>
            <button id="menu-toggle" class="md:hidden p-1 text-slate-400 hover:text-white focus:outline-none transition-colors" aria-label="Abrir menú">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
            </button>
        </div>
    </div>
    <div id="mobile-menu" class="fixed inset-y-0 left-0 z-50 w-full max-w-xs bg-slate-900/95 backdrop-blur-lg border-r border-slate-800 p-6 flex flex-col justify-between -translate-x-full transition-transform duration-300 ease-in-out md:hidden shadow-2xl">
        <div>
            <div class="flex items-center justify-between mb-6">
                <span class="text-xl font-bold tracking-wider text-white">UCQ<span class="text-indigo-500">.</span></span>
                <button id="menu-close" class="p-1 text-slate-400 hover:text-white transition-colors" aria-label="Cerrar menú">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <hr class="mb-6 text-white">
            <nav class="flex flex-col gap-5 text-lg font-medium">
                <a href="#sobre-mi" class="mobile-link text-slate-300 hover:text-white py-1 transition-colors">Sobre mí</a>
                <a href="#experiencia" class="mobile-link text-slate-300 hover:text-white py-1 transition-colors">Experiencia</a>
                <a href="#proyectos" class="mobile-link text-slate-300 hover:text-white py-1 transition-colors">Proyectos</a>
                <a href="#stack" class="mobile-link text-slate-300 hover:text-white py-1 transition-colors">Stack</a>
                <a href="#contacto" class="mobile-link text-slate-300 hover:text-white py-1 transition-colors">Contacto</a>
            </nav>
            <div class="flex flex-col justify-center items-center mt-4 text-white">
                <span>ThemeToggle</span>
                <span>LanguageDropdown</span>
            </div>
        </div>
    </div>
    <div id="menu-overlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-40 hidden md:hidden opacity-0 transition-opacity duration-300"></div>
</header>

<script>

    const menuToggle = document.getElementById('menu-toggle');
    const menuClose = document.getElementById('menu-close');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuOverlay = document.getElementById('menu-overlay');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    
    function openMenu() {
        mobileMenu?.classList.remove('-translate-x-full');
        menuOverlay?.classList.remove('hidden');
        // Pequeño timeout para que la animación de opacidad del overlay funcione
        setTimeout(() => menuOverlay?.classList.add('opacity-100'), 10);
        document.body.style.overflow = 'hidden'; // Evita scroll al estar abierto
    }
    
    function closeMenu() {
        mobileMenu?.classList.add('-translate-x-full');
        menuOverlay?.classList.remove('opacity-100');
        setTimeout(() => menuOverlay?.classList.add('hidden'), 300);
        document.body.style.overflow = '';
    }
    
    // Event Listeners
    menuToggle?.addEventListener('click', openMenu);
    menuClose?.addEventListener('click', closeMenu);
    menuOverlay?.addEventListener('click', closeMenu);
    
    // Cerrar el menú automáticamente al hacer clic en cualquier sección
    mobileLinks.forEach(link => {
        link.addEventListener('click', closeMenu);
    });

</script>