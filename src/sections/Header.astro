---
import LinkedinIcon from "@/assets/icons/linkedin.svg";
import GithubIcon from "@/assets/icons/github.svg";
import SocialButton from "@/components/SocialButton.astro";
---

<div class="min-h-[calc(100vh-100px)] flex flex-col-reverse md:flex-row gap-6 md:gap-14 pt-10 md:pt-0">
    <!-- Left -->
    <div class="flex flex-1 flex-col justify-start items-center text-center md:justify-center md:items-start md:text-left">
        <h2 class="text-2xl font-bold text-blue-500 dark:text-blue-400 mb-5 md:mb-10">FULL STACK WEB & APP DEVELOPER</h2>
        <h1 class="font-bold text-gray-800 dark:text-gray-100">
            <span class="block text-3xl md:text-5xl mb-2">Hey, soy</span>
            <span class="block text-5xl md:text-7xl bg-linear-to-r from-[#0097B2] to-[#7ED957] bg-clip-text text-transparent">
                <span class="hidden md:inline">&gt;</span>
                Unai Cadenas
            </span>
        </h1>
        <h4 class="text-xl mt-5 md:mt-10 text-neutral-600 dark:text-neutral-200">
            Especializado en
            <span class="text-(--primary-color) dark:text-(--primary-color-dark) font-semibold">crear sitios web y apps modernos</span>,
            optimizados y adaptados a las necesidades de cada proyecto.
        </h4>
        <div class="flex flex-row gap-3 mt-6">
            <SocialButton href="https://es.linkedin.com/in/unaicadenas">
                <LinkedinIcon class="size-6" />
                <span class="font-semibold">LinkedIn</span>
            </SocialButton>
            <SocialButton href="https://github.com/unaicadenas">
                <GithubIcon class="size-6" />
                <span class="font-semibold">GitHub</span>
            </SocialButton>
        </div>
    </div>
    <!-- Right -->
    <div class="w-full h-auto md:w-1/3 flex justify-center items-center">
        <div class="relative w-60 h-60 md:w-full md:h-full">
            <div class="absolute w-full h-full -z-10 bg-[#97A6FF] opacity-80 blur-lg md:opacity-40 md:blur-3xl rounded-full md:rounded-none"></div>
            <img
                class="w-full h-full z-10 object-cover object-top md:object-contain rounded-full md:rounded-none mask-[linear-gradient(black_80%,transparent)]"
                src="/header-image.webp"
                alt="Imagen portfolio"
            >
        </div>
    </div>
</div>
