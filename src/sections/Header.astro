---
import LinkedinIcon from "@/assets/icons/linkedin.svg";
import GithubIcon from "@/assets/icons/github.svg";
import ArrowIcon from "@/assets/icons/download-arrow.svg";
---

<header class="h-screen">
    <div class="px-4 scroll-m-20 w-full mx-auto container lg:max-w-6xl md:max-w-4xl">
        <div class="h-screen flex justify-between items-center gap-20">
            <section class="text-center">
                <div class="flex flex-col justify-center items-center">
                    <h1 class="text-6xl font-bold text-white">Hi, I am <span class="text-green-400">Unai Cadenas</span></h1>
                    <div class="mt-10 mb-6 h-1 w-40 bg-white"></div>
                    <h2 class="text-3xl font-bold text-blue-400">FULL STACK WEB DEVELOPER</h2>
                </div>
                <h4 class="text-2xl mt-6">
                    Apasionado del
                    <span class="text-(--primary-color) font-semibold">desarrollo frontend</span>
                    . Disfruto creando interfaces
                    <span class="text-(--primary-color) font-semibold">simples, modernas y funcionales,</span>
                    cuidando la experiencia
                    de usuario y el detalle visual.
                </h4>
                <div class="mt-8 w-full flex justify-center items-center gap-6">
                    <a href="/" class="border border-(--primary-color) px-4 py-2 rounded-full hover:scale-110 transition">
                        <div class="flex justify-center items-center">
                            <ArrowIcon class="size-7 text-(--primary-color)" />
                            <span class="text-(--primary-color) font-bold">CV</span>
                        </div>
                    </a>
                    <a href="https://es.linkedin.com/in/unaicadenas" target="_blank">
                        <LinkedinIcon class="size-10 text-white hover:scale-110 transition" />
                    </a>
                    <a href="https://github.com/unaicadenas" target="_blank">
                        <GithubIcon class="size-10 text-white hover:scale-110 transition" />
                    </a>
                </div>
            </section>
            <!-- <section class="hidden md:flex">
                <img src="/" alt="Imagen posando">
            </section> -->
        </div>
    </div>
</header>

<style>

    header {
        background:
            linear-gradient(
            to bottom,
            transparent 40%,
            oklch(21% 0.034 264.665) 100%
            ),
            radial-gradient(circle at 50% 50%, rgba(56,189,248,0.18), transparent 85%),
            radial-gradient(circle at 50% 50%, rgba(34,197,94,0.15), transparent 90%),
            linear-gradient(180deg, #020617, #0f172a);
    }

</style>