---
import ExperienceSection from "@/components/ExperienceSection.astro";

const Experiencias = [
    {
        time: "Octubre 2023 - Actualidad",
        title: "Desarrollador web senior",
        job: "Ibermática",
    },
    {
        time: "Junio 2018 - Junio 2019",
        title: "Desarrollador web senior",
        job: "Ibermática",
    },
    {
        time: "Septiembre 2017 - Junio 2019",
        title: "Desarrollador web senior",
        job: "Ibermática",
    },
]

---

<div class="w-full max-w-4xl mx-auto">
    <div class="flex flex-col gap-14">
        {
            Experiencias.map((experiencia, index) => (
                <div class={`flex justify-between items-center ${index % 2 === 0 ? 'flex-row' : 'flex-row-reverse'}`}>
                    <time class="text-(--primary-color) dark:text-(--primary-color-dark) font-bold">{experiencia.time}</time>
                    <div class="w-4 h-4 bg-(--primary-color) dark:bg-(--primary-color-dark) rounded-full"></div>
                    <div class={`max-w-2/3 bg-slate-50 dark:bg-white/5 px-6 py-4 border border-slate-200 dark:border-white/10 rounded-2xl flex flex-col ${index % 2 === 0 ? 'border-l-5 border-l-green-400 items-start' : 'border-r-5 border-r-green-400 items-end'}`}>
                        <h2 class="text-xl font-bold">Desarrollador web senior</h2>
                        <h3 class="text-lg font-semibold mb-2">Ibermática / Ayesa</h3>
                        <p>Lorem, ipsum dolor sit amet consectetur adipisicing elit. Optio suscipit non delectus dignissimos! Esse blanditiis harum perferendis ex a ad delectus at dolores, doloribus aperiam dolorum omnis, veniam voluptatum eos.</p>
                    </div>
                </div>
            ))
        }
    </div>
</div>

