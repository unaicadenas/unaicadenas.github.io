---
import '@/styles/global.css';

import Navbar from "@/sections/Navbar.astro";
import Footer from "@/sections/Footer.astro";

interface Props {
	title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="text-black dark:text-white">
		<Navbar />
		<slot />
		<Footer />
	</body>
</html>

<style is:global>
	:root {
		--primary-color: #4ddf9e;
	}
	html {
		background:
			radial-gradient(circle at 15% 20%, rgba(77, 223, 158, 0.15) 0%, transparent 30%),
			radial-gradient(circle at 85% 30%, rgba(59, 130, 246, 0.12) 0%, transparent 35%),
			radial-gradient(circle at 50% 80%, rgba(96, 165, 250, 0.1) 0%, transparent 40%),
			linear-gradient(135deg,#f8fafc 0%,#eef6ff 50%,#f0fdf4 100%
		);
	}
	.dark {
		background:
			radial-gradient(circle at 20% 20%, rgba(77, 223, 158, 0.15) 0%, transparent 30%),
			radial-gradient(circle at 80% 30%, rgba(59, 130, 246, 0.18) 0%, transparent 35%),
			radial-gradient(circle at 50% 90%, rgba(37, 99, 235, 0.12) 0%, transparent 40%),
			linear-gradient(135deg,#020617 0%,#0f172a 45%,#111827 100%
		);
		/*background: oklch(21% 0.034 264.665);*/
	}
	body {
		margin: 0;
		display: grid;
		min-height: 100dvh;
		grid-template-rows: auto 1fr auto;
	}
	[id] {
		scroll-margin-top: 120px;
	}
</style>
