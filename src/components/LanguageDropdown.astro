---

import esFlag from "@/assets/flags/es.svg";
import euFlag from "@/assets/flags/eu.svg";
import enFlag from "@/assets/flags/en.svg";

const languages = [
    { code: 'es', name: 'Español', flag: esFlag },
    { code: 'eu', name: 'Euskera', flag: euFlag },
    { code: 'en', name: 'English', flag: enFlag }
];

// Idioma por defecto
const currentLanguage = languages[0];

---

<div class="relative inline-block text-left w-full sm:w-auto text-gray-700 dark:text-gray-200" id="language-dropdown-container">
    <button
        type="button"
        class="inline-flex items-center justify-between sm:justify-center gap-x-1 w-full sm:w-auto text-sm font-medium transition-all duration-200"
        id="dropdown-button"
        aria-expanded="false"
        aria-haspopup="true"
    >
        <div class="flex items-center gap-3 sm:gap-2">
            <img
                src={currentLanguage.flag.src}
                alt={currentLanguage.name}
                class="w-5 h-5 rounded-full object-cover border border-gray-100 dark:border-zinc-700 shrink-0"
            />
            <!-- 
            <span class="block truncate uppercase text-white">{currentLanguage.code}</span>
            -->
        </div>
        <svg class="h-5 w-5 text-gray-400 transition-transform duration-200" id="dropdown-chevron" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
    </button>
    <div
        class="hidden absolute right-0 z-50 mt-2 w-full sm:w-48 origin-top-right rounded-xl bg-white dark:bg-zinc-900 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none transform scale-95 opacity-0 transition-all duration-200"
        id="dropdown-menu"
        role="menu"
        aria-orientation="vertical"
        aria-labelledby="dropdown-button"
    >
        <div class="py-1 p-1" role="none">
            {languages.map((lang) => (
            <a
                href={`/${lang.code}`} 
                class="flex items-center gap-3 px-4 py-2 text-sm rounded-lg hover:bg-gray-100 dark:hover:bg-zinc-800 transition-colors duration-150 group"
                role="menuitem"
            >
                <img 
                    src={lang.flag.src} 
                    alt={lang.name} 
                    class="w-5 h-5 rounded-full object-cover border border-gray-100 dark:border-zinc-700 shrink-0 group-hover:scale-105 transition-transform"
                />
                <span class={`${lang.code === currentLanguage.code ? 'font-semibold text-indigo-600 dark:text-indigo-400' : 'font-normal'}`}>
                    {lang.name}
                </span>
            </a>
            ))}
        </div>
    </div>
</div>

<script>

    // Lógica en el cliente para abrir/cerrar el dropdown de forma accesible
    const container = document.getElementById('language-dropdown-container');
    const button = document.getElementById('dropdown-button');
    const menu = document.getElementById('dropdown-menu');
    const chevron = document.getElementById('dropdown-chevron');

    if (button && menu && chevron) {
        const toggleDropdown = () => {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', (!isExpanded).toString());
      
        if (isExpanded) {
            // Cerrar
            menu.classList.add('hidden', 'scale-95', 'opacity-0');
            menu.classList.remove('scale-100', 'opacity-100');
            chevron.classList.remove('rotate-180');
            } else {
                // Abrir
                menu.classList.remove('hidden');
                // Pequeño timeout para que la transición de Tailwind funcione al quitar 'hidden'
                setTimeout(() => {
                    menu.classList.remove('scale-95', 'opacity-0');
                    menu.classList.add('scale-100', 'opacity-100');
                }, 10);
                chevron.classList.add('rotate-180');
            }
        };
        button.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleDropdown();
    });

    // Cerrar si se hace clic fuera del dropdown
    document.addEventListener('click', (e) => {
        if (container && !container.contains(e.target as Node)) {
            button.setAttribute('aria-expanded', 'false');
            menu.classList.add('hidden', 'scale-95', 'opacity-0');
            menu.classList.remove('scale-100', 'opacity-100');
            chevron.classList.remove('rotate-180');
        }
    });
}

</script>