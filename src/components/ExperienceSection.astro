---
interface Props {
    title: string
    company: string
    description: string
    date: string
    current?: boolean
}

const { title, company, description, date, current = false } = Astro.props;
---

<div class="ml-8">
    <div class="absolute -left-2 mt-1.5 bg-(--primary-color) dark:bg-(--primary-color-dark) h-4 w-4 rounded-full"></div>
    <div class="flex flex-col md:flex-row justify-between items-start gap-4">
        <time class="p-0 m-0 px-4 py-1 rounded-full font-semibold text-sm text-gray-800 bg-gray-100 border border-gray-300 dark:bg-gray-800 dark:border-gray-600 dark:text-white">{date}</time>
        <div class="md:w-2/3 bg-slate-50 dark:bg-white/5 px-6 py-4 border border-slate-200 dark:border-white/10 rounded-2xl flex flex-col border-l-5 border-l-slate-300 shadow-md">
            <h2 class="text-xl font-bold text-(--primary-color) dark:text-(--primary-color-dark)">{title}</h2>
            <h3 class="text-lg font-semibold text-slate-800 dark:text-slate-100 mb-3">{company}</h3>
            <p class="text-slate-600 dark:text-slate-400">{description}</p>
        </div>
    </div>
</div>
