---
import Layout from '@/layouts/Layout.astro';
import Header from "@/sections/Header.astro";
import Card from "@/components/Card.astro";
import Stack from "@/components/Stack.astro";
---

<Layout title="Unai Cadenas Portfolio Web">

	<!-- HEADER -->
	<Header />

	<div id="sobremi"></div>
	
	<div class="space-y-30 px-4 scroll-m-20 w-full mx-auto container lg:max-w-6xl md:max-w-4xl">

		<!-- Sobre mi -->
		<section class="text-center">
			<h1 class="text-5xl mb-20 font-bold text-(--primary-color)">Sobre mí</h1>
			<div class="space-y-6">
				<p>
					Soy desarrollador web con enfoque Full Stack, apasionado por crear aplicaciones modernas,
					funcionales y bien estructuradas. Me gusta transformar ideas en productos digitales reales,
					cuidando tanto la experiencia de usuario como la calidad del código.
				</p>
				<p>
					Trabajo principalmente con tecnologías del backend y frontend, siempre buscando
					soluciones limpias, escalables y mantenibles. Disfruto programando, aprendiendo nuevas
					herramientas y mejorando constantemente mis habilidades técnicas.
				</p>
				<p>
					Me considero una persona curiosa, autodidacta y orientada a resultados. Cuando no estoy
					escribiendo código, estoy explorando nuevas tecnologías, optimizando proyectos o aprendiendo
					algo nuevo que pueda aportar valor a mis desarrollos.
				</p>
				<p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Dolor libero expedita facilis dolorum
					quidem qui, excepturi a quasi ullam debitis saepe animi quae incidunt asperiores, perferendis enim
					iste accusantium optio!
				</p>
				<p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Velit doloremque ut in debitis reprehenderit
					voluptate recusandae accusantium, saepe error minus, quasi quia cumque placeat itaque sit vero a
					excepturi perspiciatis?
				</p>
			</div>
		</section>

		<div id="experience"></div>
		
		<!-- Experiencia laboral -->
		<section>
			<h1 class="text-5xl mb-20 font-bold text-(--primary-color) text-center">Experiencia laboral</h1>
			<div class="relative mx-auto max-w-5xl">
		<!-- Línea -->
		<div class="absolute left-4 top-0 h-full w-px bg-white/10 md:left-1/2"></div>

		<!-- Experiencia 1 -->
		<div class="relative mb-12 flex md:justify-start">
			<div class="absolute left-4 top-8 h-4 w-4 -translate-x-1/2 rounded-full bg-(--primary-color) md:left-1/2"></div>

			<div class="ml-12 w-full md:mr-12 md:w-[calc(50%-3rem)]">
				<div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm">
					<span class="text-sm text-zinc-400">2024 - Actualidad</span>

					<h3 class="mt-2 text-xl font-semibold">
						Frontend Developer
					</h3>

					<p class="mt-1 text-(--primary-color)">
						Empresa 1
					</p>

					<p class="mt-4 text-zinc-400">
						Desarrollo de aplicaciones web modernas utilizando Astro,
						React y Tailwind CSS.
					</p>
				</div>
			</div>
		</div>

		<!-- Experiencia 2 -->
		<div class="relative mb-12 flex md:justify-end">
			<div class="absolute left-4 top-8 h-4 w-4 -translate-x-1/2 rounded-full bg-(--primary-color) md:left-1/2"></div>

			<div class="ml-12 w-full md:ml-12 md:w-[calc(50%-3rem)]">
				<div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm">
					<span class="text-sm text-zinc-400">2023 - 2024</span>

					<h3 class="mt-2 text-xl font-semibold">
						Full Stack Developer
					</h3>

					<p class="mt-1 text-(--primary-color)">
						Empresa 2
					</p>

					<p class="mt-4 text-zinc-400">
						Desarrollo de APIs, bases de datos y optimización de
						rendimiento.
					</p>
				</div>
			</div>
		</div>

		<!-- Experiencia 3 -->
		<div class="relative flex md:justify-start">
			<div class="absolute left-4 top-8 h-4 w-4 -translate-x-1/2 rounded-full bg-(--primary-color) md:left-1/2"></div>

			<div class="ml-12 w-full md:mr-12 md:w-[calc(50%-3rem)]">
				<div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm">
					<span class="text-sm text-zinc-400">2022 - 2023</span>

					<h3 class="mt-2 text-xl font-semibold">
						Web Developer
					</h3>

					<p class="mt-1 text-(--primary-color)">
						Empresa 3
					</p>

					<p class="mt-4 text-zinc-400">
						Creación y mantenimiento de sitios web corporativos.
					</p>
				</div>
			</div>
		</div>
	</div>
		</section>

		<div id="proyectos"></div>
		
		<!-- Proyectos -->
		<section>
			<h1 class="text-5xl mb-20 font-bold text-(--primary-color) text-center">Proyectos</h1>
			<div class="flex flex-col gap-16">
				<Card />
				<Card />
			</div>
		</section>

		<div id="stack"></div>

		<!-- Stack Tecnologico -->
		<section class="text-center">
			<h1 class="text-5xl mb-20 font-bold text-(--primary-color)">Stack Tecnológico</h1>
			<Stack />
		</section>

		<div id="contacto"></div>

		<!-- Contacto -->
		<section>
			<h1 class="text-5xl mb-20 font-bold text-(--primary-color) text-center">Contacto</h1>
			<form>
				<div class="pb-6">
					<!-- Formulario -->
					<div class="mt-10 grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-6">
						<!-- Nombre -->
						<div class="sm:col-span-3">
							<label for="first-name" class="block text-sm/6 font-medium text-white">Nombre</label>
							<div class="mt-2">
								<input id="first-name" type="text" name="first-name" autocomplete="given-name" class="block w-full rounded-md bg-white/5 px-3 py-1.5 text-base text-white outline-1 -outline-offset-1 outline-white/10 placeholder:text-gray-500 focus:outline-2 focus:-outline-offset-2 focus:outline-(--primary-color) sm:text-sm/6" />
							</div>
						</div>
						<!-- Apellidos -->
						<div class="sm:col-span-3">
							<label for="last-name" class="block text-sm/6 font-medium text-white">Apellidos</label>
							<div class="mt-2">
								<input id="last-name" type="text" name="last-name" autocomplete="family-name" class="block w-full rounded-md bg-white/5 px-3 py-1.5 text-base text-white outline-1 -outline-offset-1 outline-white/10 placeholder:text-gray-500 focus:outline-2 focus:-outline-offset-2 focus:outline-(--primary-color) sm:text-sm/6" />
							</div>
						</div>
						<!-- Email -->
						<div class="col-span-full">
							<label for="email" class="block text-sm/6 font-medium text-white">Email</label>
							<div class="mt-2">
								<input id="email" type="email" name="email" autocomplete="email" class="block w-full rounded-md bg-white/5 px-3 py-1.5 text-base text-white outline-1 -outline-offset-1 outline-white/10 placeholder:text-gray-500 focus:outline-2 focus:-outline-offset-2 focus:outline-(--primary-color) sm:text-sm/6" />
							</div>
						</div>
						<!-- Comentario -->
						<div class="col-span-full">
							<label for="about" class="block text-sm/6 font-medium text-white">Comentario</label>
							<div class="mt-2">
								<textarea id="about" name="about" rows="3" class="block w-full rounded-md bg-white/5 px-3 py-1.5 text-base text-white outline-1 -outline-offset-1 outline-white/10 placeholder:text-gray-500 focus:outline-2 focus:-outline-offset-2 focus:outline-(--primary-color) sm:text-sm/6"></textarea>
							</div>
							<p class="mt-3 text-sm/6 text-gray-400">Mándame un correo o contáctame por Linkedin.</p>
						</div>
					</div>
				</div>
				<div class="text-center">
					<button type="submit" class="rounded-full bg-(--primary-color) px-6 py-2 text-sm font-semibold text-black focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500">Enviar</button>
				</div>
			</form>
		</section>

	</div>

</Layout>
