---
import Layout from '@/layouts/Layout.astro';
import Card from "@/components/Card.astro";

import Header from "@/sections/Header.astro";
import AboutMe from "@/sections/AboutMe.astro";
import Stack from "@/sections/Stack.astro";
import Contact from "@/sections/Contact.astro";
---

<Layout title="Portfolio Unai Cadenas - Desarrollador full stack web">

	<!-- HEADER -->
	<Header />

	<div id="sobre-mi"></div>
	
	<div class="space-y-30 px-4 scroll-m-20 w-full mx-auto container lg:max-w-6xl md:max-w-4xl">

		<!-- Sobre mi -->
		<AboutMe />

		<div id="experiencia"></div>
		
		<!-- Experiencia laboral -->
		<section>
			<div class="mb-20 flex flex-col justify-center items-center">
				<h1 class="text-4xl md:text-5xl font-bold text-white">Experiencia laboral</h1>
				<div class="mt-4 h-1 w-20 bg-(--primary-color)"></div>
			</div>
			<!--
			<h1 class="text-5xl mb-20 font-bold text-(--primary-color) text-center">Experiencia laboral</h1>
			-->

			<!-- Start timeline -->

			<div class="relative max-w-4xl mx-auto">
				<!-- Línea -->
				<div class="absolute left-5 top-0 bottom-0 w-px bg-white/10"></div>

				<!-- Experiencia -->
				<div class="group relative pl-16 pb-12">
					<div
						class="absolute left-5 top-2 h-4 w-4 -translate-x-1/2 rounded-full bg-(--primary-color) ring-4 ring-black transition-all duration-300 group-hover:scale-125 group-hover:shadow-lg group-hover:shadow-(--primary-color)/50"
					></div>

					<div
						class="rounded-3xl border border-white/10 bg-white/3 backdrop-blur-xl p-6 transition-all duration-300 hover:border-white/20 hover:bg-white/5"
					>
						<div class="flex flex-wrap items-center gap-3 mb-4">
							<span
								class="rounded-full border border-(--primary-color)/20 bg-(--primary-color)/10 px-3 py-1 text-xs font-medium text-(--primary-color)"
							>
								2024 - Actualidad
							</span>
						</div>

						<h3 class="text-xl font-semibold">
							Frontend Developer
						</h3>

						<p class="mt-1 text-zinc-400">
							Empresa 1
						</p>

						<p class="mt-4 text-zinc-500 leading-relaxed">
							Desarrollo de aplicaciones web modernas utilizando Astro,
							React, TypeScript y Tailwind CSS.
						</p>
					</div>
				</div>

				<!-- Experiencia -->
				<div class="group relative pl-16 pb-12">
					<div
						class="absolute left-5 top-2 h-4 w-4 -translate-x-1/2 rounded-full bg-(--primary-color) ring-4 ring-black transition-all duration-300 group-hover:scale-125 group-hover:shadow-lg group-hover:shadow-(--primary-color)/50"
					></div>

					<div
						class="rounded-3xl border border-white/10 bg-white/3 backdrop-blur-xl p-6 transition-all duration-300 hover:border-white/20 hover:bg-white/5"
					>
						<span
							class="mb-4 inline-flex rounded-full border border-(--primary-color)/20 bg-(--primary-color)/10 px-3 py-1 text-xs font-medium text-(--primary-color)"
						>
							2023 - 2024
						</span>

						<h3 class="text-xl font-semibold">
							Full Stack Developer
						</h3>

						<p class="mt-1 text-zinc-400">
							Empresa 2
						</p>

						<p class="mt-4 text-zinc-500 leading-relaxed">
							Desarrollo de APIs, bases de datos y optimización del rendimiento.
						</p>
					</div>
				</div>

				<!-- Experiencia -->
				<div class="group relative pl-16">
					<div
						class="absolute left-5 top-2 h-4 w-4 -translate-x-1/2 rounded-full bg-(--primary-color) ring-4 ring-black transition-all duration-300 group-hover:scale-125 group-hover:shadow-lg group-hover:shadow-(--primary-color)/50"
					></div>

					<div
						class="rounded-3xl border border-white/10 bg-white/3 backdrop-blur-xl p-6 transition-all duration-300 hover:border-white/20 hover:bg-white/5"
					>
						<span
							class="mb-4 inline-flex rounded-full border border-(--primary-color)/20 bg-(--primary-color)/10 px-3 py-1 text-xs font-medium text-(--primary-color)"
						>
							2022 - 2023
						</span>

						<h3 class="text-xl font-semibold">
							Web Developer
						</h3>

						<p class="mt-1 text-zinc-400">
							Empresa 3
						</p>

						<p class="mt-4 text-zinc-500 leading-relaxed">
							Creación y mantenimiento de sitios web corporativos.
						</p>
					</div>
				</div>
			</div>

			<!-- End timeline -->

		</section>

		<div id="proyectos"></div>
		
		<!-- Proyectos -->
		<section>
			<div class="mb-20 flex flex-col justify-center items-center">
				<h1 class="text-4xl md:text-5xl font-bold text-white">Proyectos</h1>
				<div class="mt-4 h-1 w-20 bg-(--primary-color)"></div>
			</div>
			<!--
			<h1 class="text-5xl mb-20 font-bold text-(--primary-color) text-center">Proyectos</h1>
			-->
			<div class="flex gap-16">
				<Card />
				<Card />
				<Card />
			</div>
		</section>

		<!-- Stack Tecnologico -->
		<div id="stack"></div>
		<Stack />

		<!-- Contacto -->
		<div id="contacto"></div>
		<Contact />

	</div>

</Layout>
